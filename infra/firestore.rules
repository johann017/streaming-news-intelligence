rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // events collection: read by authenticated users, no client writes.
    // The pipeline writes via Admin SDK which bypasses these rules entirely.
    match /events/{eventId} {
      // Allow authenticated reads (for future frontend)
      allow read: if request.auth != null;

      // Deny all client writes — only the pipeline (Admin SDK) may write
      allow write: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
