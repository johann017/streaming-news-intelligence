# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Notifications ─────────────────────────────────────────────────────────────
# Your private ntfy.sh topic name. Anyone who knows this can notify you.
# Pick something unguessable (e.g., a UUID or random string).
NTFY_TOPIC=your-secret-topic-name-here

# ── Firebase ──────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON key (local dev only).
# In GitHub Actions, set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON content.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Pipeline tuning (optional overrides) ─────────────────────────────────────
# DBSCAN_EPS=0.25
# TOP_CLUSTERS_KEPT=50
# MIN_SCORE_FOR_SUMMARIZATION=0.3
# NOTIFICATION_SCORE_THRESHOLD=0.7
# EVENT_TTL_HOURS=48
# TOP_EVENT_TTL_HOURS=72
